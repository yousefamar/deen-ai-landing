---
permalink: sitemap.xml
eleventyExcludeFromCollections: true
---
<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9"
        xmlns:xhtml="http://www.w3.org/1999/xhtml">
{%- set baseUrl = "https://deen.ai/" -%}
{%- for code in locales %}
  <url>
    <loc>{{ baseUrl if code == "en" else (baseUrl + code + "/") }}</loc>
    {%- for alt in locales %}
    <xhtml:link rel="alternate" hreflang="{{ i18n[alt].htmlLang }}" href="{{ baseUrl if alt == "en" else (baseUrl + alt + "/") }}"/>
    {%- endfor %}
    <xhtml:link rel="alternate" hreflang="x-default" href="{{ baseUrl }}"/>
    <lastmod>2026-06-29</lastmod>
    <changefreq>weekly</changefreq>
    <priority>{{ "1.0" if code == "en" else "0.9" }}</priority>
  </url>
{%- endfor %}
  <url>
    <loc>https://deen.ai/privacy/</loc>
    <lastmod>2026-06-24</lastmod>
    <changefreq>yearly</changefreq>
    <priority>0.3</priority>
  </url>
</urlset>
