---
permalink: "index.html"
---
{%- set listEls = [] -%}
{%- for item in gallery -%}
{%- if not item.hidden -%}
{%- set _ = listEls.push({ "@type": "ListItem", "position": listEls.length + 1, "url": item.url, "name": item.title, "description": item.description }) -%}
{%- endif -%}
{%- endfor -%}
<!doctype html>
<html lang="en">

<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <title>deen.ai · Islamic AI tools, datasets &amp; models</title>
  <meta name="description" content="deen.ai is a curated directory of AI tools, datasets, models and research at the intersection of artificial intelligence and Islam.">
  <link rel="canonical" href="https://deen.ai/">
  <meta name="robots" content="index,follow,max-image-preview:large,max-snippet:-1,max-video-preview:-1">
  <meta name="theme-color" content="#1F3938">

  <!-- Open Graph -->
  <meta property="og:type" content="website">
  <meta property="og:site_name" content="deen.ai">
  <meta property="og:title" content="deen.ai · AI + Islam">
  <meta property="og:description" content="A curated directory of AI tools, datasets, models and research at the intersection of artificial intelligence and Islam.">
  <meta property="og:url" content="https://deen.ai/">
  <meta property="og:locale" content="en_GB">
  <meta property="og:image" content="https://deen.ai/og-image.png">
  <meta property="og:image:type" content="image/png">
  <meta property="og:image:width" content="1200">
  <meta property="og:image:height" content="630">
  <meta property="og:image:alt" content="deen.ai · AI + Islam">

  <!-- Twitter -->
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="deen.ai · AI + Islam">
  <meta name="twitter:description" content="A curated directory of AI tools, datasets, models and research at the intersection of artificial intelligence and Islam.">
  <meta name="twitter:image" content="https://deen.ai/og-image.png">

  <!-- Icons / manifest -->
  <link rel="icon" href="/favicon.ico" sizes="any">
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png">
  <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png">
  <link rel="apple-touch-icon" href="/apple-touch-icon.png">
  <link rel="manifest" href="/site.webmanifest">

  <link rel="stylesheet" href="/tailwind.css">

  <script type="application/ld+json">
  {{ { "@context": "https://schema.org", "@type": "Organization", "name": "deen.ai", "url": "https://deen.ai/", "logo": "https://deen.ai/android-chrome-512x512.png", "description": "A curated directory of AI tools, datasets, models and research at the intersection of artificial intelligence and Islam." } | dump | safe }}
  </script>
  <script type="application/ld+json">
  {{ { "@context": "https://schema.org", "@type": "WebSite", "name": "deen.ai", "url": "https://deen.ai/" } | dump | safe }}
  </script>
  <script type="application/ld+json">
  {{ { "@context": "https://schema.org", "@type": "CollectionPage", "name": "deen.ai · AI + Islam", "url": "https://deen.ai/", "description": "A curated directory of AI tools, datasets, models and research at the intersection of artificial intelligence and Islam.", "mainEntity": { "@type": "ItemList", "numberOfItems": listEls.length, "itemListElement": listEls } } | dump | safe }}
  </script>
</head>

<body>

<div class="h-screen flex items-center justify-center bg-gradient-to-b from-cyan-50 to-green-50">
  <div class="relative isolate">
    <div class="mx-auto max-w-2xl">
      <div class="py-32 sm:py-48 lg:py-56">
        <div class="hidden sm:mb-8 sm:flex sm:justify-center">
        </div>
        <div class="text-center">
          <div class="flex flex-col sm:flex-row items-center justify-center">
            <img src="/deen.png" alt="deen.ai logo" width="64" height="64" class="w-16 mb-4 sm:mr-4 sm:mb-0">
            <h1 class="text-4xl font-bold tracking-tight text-gray-900 sm:text-6xl">deen.ai</h1>
          </div>
          <p class="mt-6 text-lg leading-8 text-gray-600">AI + Islam</p>
          <div class="mt-10 flex items-center justify-center gap-x-6">
            <a href="https://wa.me/12056799898?text=Assalamu%20alaikum%2C%20I%20would%20like%20to%20join%20the%20deen.ai%20community" target="_blank" rel="noopener"
              class="inline-flex items-center rounded-md bg-green-600 px-3.5 py-2.5 text-sm font-semibold text-white shadow-sm hover:bg-green-500 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-green-600">
              <svg class="mr-2 h-5 w-5 fill-current" viewBox="0 0 448 512" aria-hidden="true"><path d="M380.9 97.1C339 55.1 283.2 32 223.9 32c-122.4 0-222 99.6-222 222 0 39.1 10.2 77.3 29.6 111L0 480l117.7-30.9c32.4 17.7 68.9 27 106.1 27h.1c122.3 0 224.1-99.6 224.1-222 0-59.3-25.2-115-67.1-157zm-157 341.6c-33.2 0-65.7-8.9-94-25.7l-6.7-4-69.8 18.3L72 359.2l-4.4-7c-18.5-29.4-28.2-63.3-28.2-98.2 0-101.7 82.8-184.5 184.6-184.5 49.3 0 95.6 19.2 130.4 54.1 34.8 34.9 56.2 81.2 56.1 130.5 0 101.8-84.9 184.6-186.6 184.6zm101.2-138.2c-5.5-2.8-32.8-16.2-37.9-18-5.1-1.9-8.8-2.8-12.5 2.8-3.7 5.6-14.3 18-17.6 21.8-3.2 3.7-6.5 4.2-12 1.4-32.6-16.3-54-29.1-75.5-66-5.7-9.8 5.7-9.1 16.3-30.3 1.8-3.7.9-6.9-.5-9.7-1.4-2.8-12.5-30.1-17.1-41.2-4.5-10.8-9.1-9.3-12.5-9.5-3.2-.2-6.9-.2-10.6-.2-3.7 0-9.7 1.4-14.8 6.9-5.1 5.6-19.4 19-19.4 46.3 0 27.3 19.9 53.7 22.6 57.4 2.8 3.7 39.1 59.7 94.8 83.8 35.2 15.2 49 16.5 66.6 13.9 10.7-1.6 32.8-13.4 37.4-26.4 4.6-13 4.6-24.1 3.2-26.4-1.3-2.5-5-3.9-10.5-6.6z"/></svg>
              Join the community</a>
          </div>
        </div>
      </div>
    </div>
    <svg class="absolute bottom-0 left-1/2 h-9 w-9 -translate-x-1/2 text-gray-500 fill-current" viewBox="0 0 512 512" aria-hidden="true"><path d="M233.4 406.6c12.5 12.5 32.8 12.5 45.3 0l192-192c12.5-12.5 12.5-32.8 0-45.3s-32.8-12.5-45.3 0L256 338.7 86.6 169.4c-12.5-12.5-32.8-12.5-45.3 0s-12.5 32.8 0 45.3l192 192z"/></svg>
  </div>
</div>

<h2 class="mx-auto max-w-2xl text-center text-3xl font-bold tracking-tight text-gray-900 sm:text-4xl mt-20">Gallery</h2>

<div class="mx-auto max-w-2xl px-4 py-16 sm:px-6 sm:py-24 lg:max-w-7xl lg:px-8">
  <div class="grid grid-cols-1 gap-y-4 sm:grid-cols-2 sm:gap-x-6 sm:gap-y-10 lg:grid-cols-3 lg:gap-x-8">

    {% for item in gallery %}
    {% if not item.hidden %}
    <div class="group relative flex flex-col overflow-hidden rounded-lg border border-gray-200 bg-white">
      <div class="aspect-h-9 aspect-w-16 bg-gray-200 group-hover:opacity-75">
        <img src="{{item.img}}" alt="{{ item.title }}" loading="lazy" decoding="async" class="h-full w-full object-cover object-top sm:h-full sm:w-full">
      </div>
      <div class="flex flex-1 flex-col space-y-2 p-4">
        <h3 class="text-md font-medium text-gray-900">
          <a href="{{item.url}}" target="_blank" rel="noopener">
            <span aria-hidden="true" class="absolute inset-0"></span>
            {{ item.title }}
          </a>
        </h3>
        <p class="text-sm text-gray-500 flex-grow">{{ item.description }}</p>
        <div class="flex gap-2 pt-2">
          {% for tag in item.tags %}
            {% if tag === 'Product' %}
              <span class="inline-flex items-center rounded-full bg-green-50 px-2 py-1 text-xs font-medium text-green-700 ring-1 ring-inset ring-green-600/20">{{ tag }}</span>
            {% elseif tag === 'Dataset' %}
              <span class="inline-flex items-center rounded-full bg-blue-50 px-2 py-1 text-xs font-medium text-blue-700 ring-1 ring-inset ring-blue-700/10">{{ tag }}</span>
            {% elseif tag === 'Model' %}
              <span class="inline-flex items-center rounded-full bg-yellow-50 px-2 py-1 text-xs font-medium text-yellow-800 ring-1 ring-inset ring-yellow-600/20">{{ tag }}</span>
            {% elseif tag === 'Code' %}
              <span class="inline-flex items-center rounded-full bg-purple-50 px-2 py-1 text-xs font-medium text-purple-700 ring-1 ring-inset ring-purple-700/10">{{ tag }}</span>
            {% elseif tag === 'Evaluation' %}
              <span class="inline-flex items-center rounded-full bg-pink-50 px-2 py-1 text-xs font-medium text-pink-700 ring-1 ring-inset ring-pink-700/10">{{ tag }}</span>
            {% endif %}
          {% endfor %}
        </div>
      </div>
    </div>
    {% endif %}
    {% endfor %}

  </div>
</div>

<footer class="bg-white">
  <div class="mx-auto max-w-7xl px-6 py-12 items-center lg:px-8">
    <div class="mt-8 md:mt-0">
      <p class="text-center text-xs leading-5 text-gray-500">Jazakallah Khayran to <a href="https://www.linkedin.com/in/waleedkadous/" target="_blank" rel="noopener" class="font-medium text-green-900">Waleed Kadous</a> for curating this list</p>
    </div>
  </div>
</footer>


</body>

</html>
